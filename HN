        TweenService:Create(uiScale, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Scale = 0.5}):Play()
        twBlur:Play(); twBlur.Completed:Wait()
        pcall(function() warnGui:Destroy(); blur:Destroy() end)
    end)
end

