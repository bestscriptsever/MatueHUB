    local isRagdolled = (currentState == Enum.HumanoidStateType.Physics or currentState == Enum.HumanoidStateType.Ragdoll or currentState == Enum.HumanoidStateType.FallingDown)
    local wasRagdolled = (lastState == Enum.HumanoidStateType.Physics or lastState == Enum.HumanoidStateType.Ragdoll or lastState == Enum.HumanoidStateType.FallingDown)
    
    if isRagdolled and not wasRagdolled then 
        startCountdown() 
        lastHitTimeForCarry = tick()
    end
