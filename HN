local autoInteractLoop = false
LogicActions.AutoInteract = function()
    if State.Toggles.AutoInteract then
        if autoInteractLoop then return end
        autoInteractLoop = true
        task.spawn(function()
            while State.Toggles.AutoInteract do
                if _G.Aimlock_Script_Versao ~= minhaVersao then break end
                local char = player.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
                if root then
                    for _, prompt in ipairs(cachedPrompts) do
                        if prompt and prompt.Parent and prompt.Enabled then
                            local part = prompt.Parent; local pos = nil
                            if part:IsA("BasePart") then pos = part.Position elseif part:IsA("Attachment") then pos = part.WorldPosition end
                            if pos and (pos - root.Position).Magnitude <= State.Values.PromptRange then
                                if fireproximityprompt then pcall(function() fireproximityprompt(prompt, 1, true) end) else pcall(function() prompt:InputHoldBegin(); task.wait(prompt.HoldDuration); prompt:InputHoldEnd() end) end
                            end
                        end
                    end
                end
                task.wait(0.1)
            end
            autoInteractLoop = false
        end)
    else autoInteractLoop = false end
end

