local frameCount, lastUpdate = 0, tick()
RunService.RenderStepped:Connect(function()
    if _G.Aimlock_Script_Versao ~= minhaVersao then return end
    frameCount = frameCount + 1
    local now = tick()
    if now - lastUpdate >= 0.5 then
        local fps = math.floor(frameCount / (now - lastUpdate))
        frameCount = 0
        lastUpdate = now
        if State.Toggles.Stats then 
            statsDisplay.Text = string.format("FPS: %d  |  %d ms", fps, currentPing) 
        else 
            statsDisplay.Text = "" 
        end
    end
end)

