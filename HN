function funcInstaReset()
    local char = player.Character
    if not char then return end
    
    local humanoid = char:FindFirstChild("Humanoid")
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    
    if rootPart then
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end
    
    local carpet = char:FindFirstChild("Flying Carpet")
    if carpet then carpet:Destroy() end
    
    if humanoid then
        humanoid.Health = 0
        humanoid:BreakJoints()
    end
    
    local respawnConn
    respawnConn = player.CharacterAdded:Connect(function(newChar)
        respawnConn:Disconnect()
        task.wait(0.15)
        local newHumanoid = newChar:FindFirstChildOfClass("Humanoid")
        local cam = workspace.CurrentCamera
        if newHumanoid then
            cam.CameraSubject = newHumanoid
            cam.CameraType = Enum.CameraType.Custom
        end
        local animate = newChar:FindFirstChild("Animate")
        if animate and animate:IsA("LocalScript") then
            animate.Disabled = true
            task.wait(0.05)
            animate.Disabled = false
        end
    end)
end

function funcTPDown()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {player.Character}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local rr = workspace:Raycast(root.Position, Vector3.new(0, -2000, 0), rp)
    if rr then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local off = (hum and hum.HipHeight or 2) + (root.Size.Y / 2)
        root.CFrame = CFrame.new(root.Position.X, rr.Position.Y + off, root.Position.Z)
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end
end

local _dropActive = false
function runDropBrainrot()
    if respawnPause or _dropActive then return end
    _dropActive = true
    
    local char = player.Character
    if not char then 
        _dropActive = false
        return 
    end
    
    local currentR = char:FindFirstChild("HumanoidRootPart")
    if not currentR then 
        _dropActive = false
        return 
    end
    
    local DROP_ASCEND_DURATION = 0.2
    local DROP_ASCEND_SPEED    = 150
    local t0 = tick()
    local dc
    
    dc = RunService.Heartbeat:Connect(function()
        local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not r then 
            dc:Disconnect()
            _dropActive = false
            return 
        end
        if tick() - t0 >= 0.15 then
            dc:Disconnect()
            r.AssemblyLinearVelocity = Vector3.zero
            
            local rp = RaycastParams.new()
            rp.FilterDescendantsInstances = {player.Character}
            rp.FilterType = Enum.RaycastFilterType.Exclude
            
            local rr = workspace:Raycast(r.Position, Vector3.new(0, -5000, 0), rp)
            if rr then
                local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
                local off = (hum and hum.HipHeight or 2) + (r.Size.Y / 2) + 0.5
                r.CFrame = CFrame.new(r.Position.X, rr.Position.Y + off, r.Position.Z)
            end
            _dropActive = false
            return
        end
        r.AssemblyLinearVelocity = Vector3.new(r.AssemblyLinearVelocity.X, DROP_ASCEND_SPEED, r.AssemblyLinearVelocity.Z)
    end)
end

local unwalkSavedAnimate = nil
local function startUnwalk()
    local c = player.Character
    if not c then return end
    local hum = c:FindFirstChildOfClass("Humanoid")
    if hum then 
        for _, t in ipairs(hum:GetPlayingAnimationTracks()) do 
            t:Stop(0) 
        end 
    end
    local anim = c:FindFirstChild("Animate")
    if anim and anim:IsA("LocalScript") then 
        anim.Disabled = true
        unwalkSavedAnimate = anim
    end
end

local function stopUnwalk()
    local c = player.Character
    if c and unwalkSavedAnimate and unwalkSavedAnimate.Parent == c then 
        unwalkSavedAnimate.Disabled = false
    end
    unwalkSavedAnimate = nil 
end

LogicActions.Unwalk = function() 
    if State.Toggles.Unwalk then 
        startUnwalk() 
    else 
        stopUnwalk() 
    end 
end

