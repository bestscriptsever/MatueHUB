                txt.TextSize = 20
                txt.TextColor3 = Theme.Primary
                txt.TextStrokeTransparency = 0.2
                txt.TextStrokeColor3 = Color3.fromRGB(0, 50, 50)
            end
            local speed = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z).Magnitude
            local displayTxt = velGui:FindFirstChild("DisplayTexto")
