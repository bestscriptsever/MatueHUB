local function CreateSlider(parentTab, titleText, valueKey, minVal, maxVal, step)
    local frame = Instance.new("Frame", parentTab)
    frame.Size = UDim2.new(1, -20, 0, 52)
    frame.BackgroundColor3 = Theme.Surface
    frame.BorderSizePixel = 0
    frame.ZIndex = 2
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    local fStroke = Instance.new("UIStroke", frame)
    fStroke.Color = Theme.Border
    fStroke.Thickness = 1

    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(0.6, 0, 0, 20)
    title.Position = UDim2.new(0, 15, 0, 5)
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.GothamMedium
    title.TextSize = 13
    title.TextColor3 = Theme.Text
    title.Text = titleText
    title.ZIndex = 2
    title.TextXAlignment = Enum.TextXAlignment.Left

    local valLabel = Instance.new("TextLabel", frame)
    valLabel.Size = UDim2.new(0.4, 0, 0, 20)
    valLabel.Position = UDim2.new(0.6, -15, 0, 5)
    valLabel.BackgroundTransparency = 1
    valLabel.Font = Enum.Font.GothamBold
    valLabel.TextSize = 13
    valLabel.TextColor3 = Theme.Primary
    valLabel.Text = tostring(State.Values[valueKey]) .. "%"
    valLabel.ZIndex = 2
    valLabel.TextXAlignment = Enum.TextXAlignment.Right

    local sliderBg = Instance.new("TextButton", frame)
    sliderBg.Size = UDim2.new(1, -30, 0, 6)
    sliderBg.Position = UDim2.new(0, 15, 0, 32)
    sliderBg.BackgroundColor3 = Theme.Background
    sliderBg.Text = ""
    sliderBg.ZIndex = 3
    sliderBg.AutoButtonColor = false
    Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1, 0)

    local sliderFill = Instance.new("Frame", sliderBg)
    sliderFill.Size = UDim2.new(0, 0, 1, 0)
    sliderFill.BackgroundColor3 = Theme.Primary
    sliderFill.BorderSizePixel = 0
    sliderFill.ZIndex = 4
    Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)

    local function UpdateVisuals(val)
        local pct = math.clamp((val - minVal) / (maxVal - minVal), 0, 1)
        TweenService:Create(sliderFill, Anim.Fast, {Size = UDim2.new(pct, 0, 1, 0)}):Play()
        valLabel.Text = tostring(val) .. "%"
    end

    InputUpdaters[valueKey] = function(v) UpdateVisuals(v) end
    UpdateVisuals(State.Values[valueKey])

    local isDragging = false
    local function UpdateValue(input)
        local mouseX = input.Position.X
        local bgAbsPos = sliderBg.AbsolutePosition.X
        local bgAbsSize = sliderBg.AbsoluteSize.X
        local pct = math.clamp((mouseX - bgAbsPos) / bgAbsSize, 0, 1)
        local rawVal = minVal + (pct * (maxVal - minVal))
        local snappedVal = math.floor(rawVal / step + 0.5) * step
        if State.Values[valueKey] ~= snappedVal then
            State.Values[valueKey] = snappedVal
            UpdateVisuals(snappedVal)
            SaveSystem()
            if LogicActions[valueKey] then LogicActions[valueKey]() end
        end
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            UpdateValue(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            UpdateValue(input)
        end
    end)
end

