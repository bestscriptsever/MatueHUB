local function SupabaseRequest(endpoint, method, payload)
    local headers = {
        ["apikey"] = SUPABASE_KEY,
        ["Authorization"] = "Bearer " .. SUPABASE_KEY,
        ["Content-Type"] = "application/json",
        ["Prefer"] = "return=representation"
    }
    local success, result = pcall(function()
        return HttpService:RequestAsync({
            Url = SUPABASE_URL .. endpoint,
            Method = method,
            Headers = headers,
            Body = payload and HttpService:JSONEncode(payload) or nil
        })
    end)
    
    if success and type(result) == "table" and result.Success then
        local decSuccess, decoded = pcall(function() 
            return HttpService:JSONDecode(result.Body) 
        end)
        if decSuccess then 
            return decoded 
        end
    end
    return nil
end

