local function isMyPlotByName(pn)
    local ct = tick()
    if StealData.plotCache[pn] and (ct - (StealData.plotCacheTime[pn] or 0)) < PLOT_CACHE_DURATION then 
        return StealData.plotCache[pn] 
    end
    
    local plots = workspace:FindFirstChild("Plots")
    if not plots then
        StealData.plotCache[pn] = false
        StealData.plotCacheTime[pn] = ct
        return false
    end
    
    local plot = plots:FindFirstChild(pn)
    if not plot then
        StealData.plotCache[pn] = false
        StealData.plotCacheTime[pn] = ct
        return false
    end
    
    local sign = plot:FindFirstChild("PlotSign")
    if sign then
        local yb = sign:FindFirstChild("YourBase")
        if yb and yb:IsA("BillboardGui") then
            local r = yb.Enabled == true
            StealData.plotCache[pn] = r
            StealData.plotCacheTime[pn] = ct
            return r
        end
    end
    
    StealData.plotCache[pn] = false
    StealData.plotCacheTime[pn] = ct
    return false
end

local function findNearestPromptSteal()
    local c = player.Character
    if not c then return nil end
    local root = c:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local ct = tick()
    if ct - StealData.promptCacheTime < PROMPT_CACHE_REFRESH and #StealData.cachedPrompts > 0 then
        local np, nd = nil, math.huge
        for _, data in ipairs(StealData.cachedPrompts) do
            if data.spawn then
                local dist = (data.spawn.Position - root.Position).Magnitude
                if dist <= State.Values.StealRadius and dist < nd then
                    np = data.prompt
                    nd = dist
                end
            end
        end
        if np then return np end
    end
    
    StealData.cachedPrompts = {}
    StealData.promptCacheTime = ct
    
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    
    local np, nd = nil, math.huge
    for _, plot in ipairs(plots:GetChildren()) do
        if isMyPlotByName(plot.Name) then continue end
        local pods = plot:FindFirstChild("AnimalPodiums")
        if not pods then continue end
        
        for _, pod in ipairs(pods:GetChildren()) do
            pcall(function()
                local base = pod:FindFirstChild("Base")
                local sp = base and base:FindFirstChild("Spawn")
                if sp then
                    local att = sp:FindFirstChild("PromptAttachment")
                    if att then
                        for _, child in ipairs(att:GetChildren()) do
                            if child:IsA("ProximityPrompt") then
                                local dist = (sp.Position - root.Position).Magnitude
                                table.insert(StealData.cachedPrompts, {prompt = child, spawn = sp})
                                if dist <= State.Values.StealRadius and dist < nd then
                                    np = child
                                    nd = dist
                                end
                                break
                            end
                        end
                    end
                end
            end)
        end
    end
    return np
end

local function executeSteal(prompt)
    local ct = tick()
    if ct - StealData.lastStealTick < STEAL_COOLDOWN then return end
    if StealData.isStealing then return end
    
    if not StealData.Data[prompt] then
        StealData.Data[prompt] = {hold = {}, trigger = {}, ready = true}
        if type(getconnections) == "function" then
            pcall(function()
                for _, c2 in ipairs(getconnections(prompt.PromptButtonHoldBegan)) do
                    if type(c2.Function) == "function" then 
                        table.insert(StealData.Data[prompt].hold, c2.Function) 
                    end
                end
                for _, c2 in ipairs(getconnections(prompt.Triggered)) do
                    if type(c2.Function) == "function" then 
                        table.insert(StealData.Data[prompt].trigger, c2.Function) 
                    end
                end
            end)
        end
    end
    
    local data = StealData.Data[prompt]
    if not data.ready then return end
    
    data.ready = false
    StealData.isStealing = true
    State.stealStartTime = ct
    StealData.lastStealTick = ct
    
    if progressFrame then 
        progressFrame.Visible = true
    end
    
    task.spawn(function()
        local startT = tick()
        local ok = false
        pcall(function()
            for _, fn in ipairs(data.hold) do task.spawn(fn) end
            
            while tick() - startT < State.Values.StealDuration do
                local prog = math.clamp((tick() - startT) / State.Values.StealDuration, 0, 1)
                if progressFill then 
                    progressFill.Size = UDim2.new(prog, 0, 1, 0) 
                end
                task.wait(0.016)
            end
            
            if progressFill then 
                progressFill.Size = UDim2.new(1, 0, 1, 0) 
            end
            
            for _, fn in ipairs(data.trigger) do task.spawn(fn) end
            ok = true
        end)
        
        if not ok and type(fireproximityprompt) == "function" then
            pcall(function() 
                fireproximityprompt(prompt)
                ok = true 
            end)
        end
        
        if not ok then
            pcall(function() 
                prompt:InputHoldBegin()
                task.wait(State.Values.StealDuration)
                prompt:InputHoldEnd() 
            end)
        end
        
        if progressFrame then 
            progressFrame.Visible = false
        end
        
        if progressFill then 
            progressFill.Size = UDim2.new(0, 0, 1, 0) 
        end
        
        data.ready = true
        StealData.isStealing = false
    end)
end

