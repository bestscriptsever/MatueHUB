    btn.Size = UDim2.new(1, 0, 0, 38)
    btn.BackgroundColor3 = Theme.Surface
    btn.AutoButtonColor = false
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.TextColor3 = Theme.TextMuted
    btn.Text = name
    btn.ZIndex = 2
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Color = Theme.Border
    btnStroke.Transparency = 1

    local scroll = Instance.new("ScrollingFrame", contentArea)
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = Theme.Primary
    scroll.BorderSizePixel = 0
    scroll.Visible = false
    scroll.ZIndex = 2
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.None
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0) 
    
    local sLayout = Instance.new("UIListLayout", scroll)
    sLayout.Padding = UDim.new(0, 8)
    sLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sLayout.SortOrder = Enum.SortOrder.LayoutOrder
    
    sLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, sLayout.AbsoluteContentSize.Y + 30)
    end)
    
    local sPad = Instance.new("UIPadding", scroll)
    sPad.PaddingTop = UDim.new(0, 15)
    sPad.PaddingBottom = UDim.new(0, 15)

    table.insert(tabs, {btn = btn, scroll = scroll})

    btn.MouseEnter:Connect(function() 
        if not scroll.Visible then TweenService:Create(btn, Anim.Fast, {BackgroundColor3 = Theme.SurfaceHover, TextColor3 = Theme.Text}):Play() end 
    end)
    btn.MouseLeave:Connect(function() 
        if not scroll.Visible then TweenService:Create(btn, Anim.Fast, {BackgroundColor3 = Theme.Surface, TextColor3 = Theme.TextMuted}):Play() end 
    end)

    btn.Activated:Connect(function()
        for _, t in ipairs(tabs) do 
            TweenService:Create(t.btn, Anim.Fast, {BackgroundColor3 = Theme.Surface, TextColor3 = Theme.TextMuted}):Play()
            t.btn:FindFirstChild("UIStroke").Transparency = 1
            t.scroll.Visible = false 
        end
        TweenService:Create(btn, Anim.Smooth, {BackgroundColor3 = Theme.Primary, TextColor3 = Theme.Background}):Play()
        btnStroke.Transparency = 0
        scroll.Visible = true
    end)
    
    return scroll
end

