    local function UpdateVisuals(val) local pct = math.clamp((val - minVal) / (maxVal - minVal), 0, 1); TweenService:Create(sliderFill, Anim.Fast, {Size = UDim2.new(pct, 0, 1, 0)}):Play(); valLabel.Text = tostring(val) .. "%" end
    InputUpdaters[valueKey] = function(v) UpdateVisuals(v) end; UpdateVisuals(State.Values[valueKey])
    local isDragging = false
    local function UpdateValue(input) local mouseX = input.Position.X; local bgAbsPos = sliderBg.AbsolutePosition.X; local bgAbsSize = sliderBg.AbsoluteSize.X; local pct = math.clamp((mouseX - bgAbsPos) / bgAbsSize, 0, 1); local rawVal = minVal + (pct * (maxVal - minVal)); local snappedVal = math.floor(rawVal / step + 0.5) * step; if State.Values[valueKey] ~= snappedVal then State.Values[valueKey] = snappedVal; UpdateVisuals(snappedVal); SaveSystem(); if type(LogicActions[valueKey]) == "function" then LogicActions[valueKey]() end end end
    sliderBg.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isDragging = true; UpdateValue(input) end end)
