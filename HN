    warnText.TextWrapped = true
    warnText.TextScaled = true
    warnText.Text = message
    warnText.TextTransparency = 1
    warnText.TextStrokeTransparency = 1
    
    local uiScale = Instance.new("UIScale", warnText)
    uiScale.Scale = 0.5

    TweenService:Create(blur, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = 25}):Play()
    TweenService:Create(bg, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {BackgroundTransparency = 0.45}):Play()
    TweenService:Create(warnText, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {TextTransparency = 0, TextStrokeTransparency = 0}):Play()
    TweenService:Create(uiScale, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()

    task.delay(4.5, function()
        if not blur or not warnGui then return end
        local twBlur = TweenService:Create(blur, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = 0})
