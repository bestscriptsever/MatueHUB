local function CreateToggle(parentTab, titleText, keyName, stateKey)
    local frame = Instance.new("Frame", parentTab)
    frame.Size = UDim2.new(1, -20, 0, 48)
    frame.BackgroundColor3 = Theme.Surface
    frame.BorderSizePixel = 0
    frame.ZIndex = 2
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    local fStroke = Instance.new("UIStroke", frame)
    fStroke.Color = Theme.Border
    fStroke.Thickness = 1

    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(0.6, 0, 1, 0)
    title.Position = UDim2.new(0, 15, 0, 0)
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.GothamMedium
    title.TextSize = 13
    title.TextColor3 = Theme.Text
    title.Text = titleText
    title.ZIndex = 2
    title.TextXAlignment = Enum.TextXAlignment.Left

    local pill = Instance.new("Frame", frame)
    pill.Size = UDim2.new(0, 42, 0, 22)
    pill.AnchorPoint = Vector2.new(1, 0.5)
    pill.Position = UDim2.new(1, -15, 0.5, 0)
    pill.BackgroundColor3 = Theme.Background
    pill.ZIndex = 2
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)

    local dot = Instance.new("Frame", pill)
    dot.Size = UDim2.new(0, 16, 0, 16)
    dot.AnchorPoint = Vector2.new(0, 0.5)
    dot.Position = UDim2.new(0, 3, 0.5, 0)
    dot.BackgroundColor3 = Theme.TextMuted
    dot.ZIndex = 3
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local overlay = Instance.new("TextButton", frame)
    overlay.Size = UDim2.new(1, 0, 1, 0)
    overlay.BackgroundTransparency = 1
    overlay.Text = ""
    overlay.ZIndex = 50

    local function VisualUpdate(isActive)
        if isActive then
            TweenService:Create(pill, Anim.Smooth, {BackgroundColor3 = Theme.Primary}):Play()
            TweenService:Create(dot, Anim.Bounce, {Position = UDim2.new(1, -19, 0.5, 0), BackgroundColor3 = Theme.Background}):Play()
            TweenService:Create(fStroke, Anim.Smooth, {Color = Theme.Primary}):Play()
            TweenService:Create(title, Anim.Smooth, {TextColor3 = Theme.Primary}):Play()
        else
            TweenService:Create(pill, Anim.Smooth, {BackgroundColor3 = Theme.Background}):Play()
            TweenService:Create(dot, Anim.Bounce, {Position = UDim2.new(0, 3, 0.5, 0), BackgroundColor3 = Theme.TextMuted}):Play()
            TweenService:Create(fStroke, Anim.Smooth, {Color = Theme.Border}):Play()
            TweenService:Create(title, Anim.Smooth, {TextColor3 = Theme.Text}):Play()
        end
        
        local mobBtn = mobileBtnsObjects[stateKey]
        if mobBtn then
            if isActive then
                mobBtn.BackgroundColor3 = Theme.Primary
                mobBtn.TextColor3 = Theme.Background
                local strk = mobBtn:FindFirstChildOfClass("UIStroke")
                if strk then strk.Color = Theme.Background end
            else
                mobBtn.BackgroundColor3 = Theme.Surface
                mobBtn.TextColor3 = Theme.Text
                local strk = mobBtn:FindFirstChildOfClass("UIStroke")
                if strk then strk.Color = Theme.Border end
            end
        end
    end
    
    if not VisualUpdaters[stateKey] then VisualUpdaters[stateKey] = {} end
    table.insert(VisualUpdaters[stateKey], VisualUpdate)

    overlay.Activated:Connect(function()
        State.Toggles[stateKey] = not State.Toggles[stateKey]
        if VisualUpdaters[stateKey] then for _, fn in ipairs(VisualUpdaters[stateKey]) do fn(State.Toggles[stateKey]) end end
        if LogicActions[stateKey] then LogicActions[stateKey]() end
        SaveSystem()
        local t = TweenService:Create(frame, Anim.Fast, {Size = UDim2.new(1, -24, 0, 46)})
        t:Play()
        t.Completed:Wait()
        TweenService:Create(frame, Anim.Bounce, {Size = UDim2.new(1, -20, 0, 48)}):Play()
    end)

    overlay.MouseEnter:Connect(function() TweenService:Create(frame, Anim.Fast, {BackgroundColor3 = Theme.SurfaceHover}):Play() end)
    overlay.MouseLeave:Connect(function() TweenService:Create(frame, Anim.Fast, {BackgroundColor3 = Theme.Surface}):Play() end)

    if keyName then
        local bindBtn = Instance.new("TextButton", frame)
        bindBtn.Size = UDim2.new(0, 30, 0, 24)
        bindBtn.AnchorPoint = Vector2.new(1, 0.5)
        bindBtn.Position = UDim2.new(1, -70, 0.5, 0)
        bindBtn.BackgroundColor3 = Theme.Background
        bindBtn.TextColor3 = Theme.Text
        bindBtn.Font = Enum.Font.GothamBold
        bindBtn.TextSize = 10
        bindBtn.Text = formatKeyName(State.Binds[keyName])
        bindBtn.ZIndex = 51
        bindBtn.AutoButtonColor = false
        Instance.new("UICorner", bindBtn).CornerRadius = UDim.new(0, 6)
        Instance.new("UIStroke", bindBtn).Color = Theme.Border
        
        table.insert(allKeybindButtonsList, {btn = bindBtn, name = keyName})

        bindBtn.Activated:Connect(function()
            if listeningAction then listeningAction.btn.Text = formatKeyName(State.Binds[listeningAction.name]) end
            bindBtn.Text = "..."
            listeningAction = { name = keyName, btn = bindBtn }
            TweenService:Create(bindBtn, Anim.Bounce, {Size = UDim2.new(0, 36, 0, 28)}):Play()
        end)
    end
end

