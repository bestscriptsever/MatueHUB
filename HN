local function CreateTab(name)
    local btn = Instance.new("TextButton")
    btn.Name = "TabBtn_" .. name
    btn.Parent = tabMenu
    btn.Size = UDim2.new(1, 0, 0, 38)
    btn.BackgroundColor3 = Theme.Surface
    btn.AutoButtonColor = false
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.TextColor3 = Theme.TextMuted
    btn.Text = name
    btn.ZIndex = 2
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.Name = "Corner"
    btnCorner.Parent = btn
    btnCorner.CornerRadius = UDim.new(0, 6)
    
    local btnStroke = Instance.new("UIStroke")
    btnStroke.Name = "Stroke"
    btnStroke.Parent = btn
    btnStroke.Color = Theme.Border
    btnStroke.Transparency = 1

    local scroll = Instance.new("ScrollingFrame")
    scroll.Name = "Scroll_" .. name
    scroll.Parent = contentArea
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = Theme.Primary
    scroll.BorderSizePixel = 0
    scroll.Visible = false
    scroll.ZIndex = 2
    
    -- Correção definitiva do Bug de opções invisíveis (Matemática Automática manual)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.None
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0) 
    
    local sLayout = Instance.new("UIListLayout")
    sLayout.Name = "Layout"
    sLayout.Parent = scroll
    sLayout.Padding = UDim.new(0, 8)
    sLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sLayout.SortOrder = Enum.SortOrder.LayoutOrder
    
    pcall(function()
        sLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scroll.CanvasSize = UDim2.new(0, 0, 0, sLayout.AbsoluteContentSize.Y + 30)
        end)
    end)
    
    local sPad = Instance.new("UIPadding")
    sPad.Name = "Padding"
    sPad.Parent = scroll
    sPad.PaddingTop = UDim.new(0, 15)
    sPad.PaddingBottom = UDim.new(0, 15)

    table.insert(tabs, {btn = btn, scroll = scroll})

    btn.MouseEnter:Connect(function() 
        if not scroll.Visible then 
            TweenService:Create(btn, Anim.Fast, {
                BackgroundColor3 = Theme.SurfaceHover, 
                TextColor3 = Theme.Text
            }):Play() 
        end 
    end)
    
    btn.MouseLeave:Connect(function() 
        if not scroll.Visible then 
            TweenService:Create(btn, Anim.Fast, {
                BackgroundColor3 = Theme.Surface, 
                TextColor3 = Theme.TextMuted
            }):Play() 
        end 
    end)

    btn.Activated:Connect(function()
        for _, t in ipairs(tabs) do 
            TweenService:Create(t.btn, Anim.Fast, {
                BackgroundColor3 = Theme.Surface, 
                TextColor3 = Theme.TextMuted
            }):Play()
            
            local str = t.btn:FindFirstChild("Stroke")
            if str then 
                str.Transparency = 1 
            end
            t.scroll.Visible = false 
        end
        
        TweenService:Create(btn, Anim.Smooth, {
            BackgroundColor3 = Theme.Primary, 
            TextColor3 = Theme.Background
        }):Play()
        btnStroke.Transparency = 0
        scroll.Visible = true
    end)
    
    return scroll
end

