local lastMaximizedPos = UDim2.new(0.5, 0, 0.5, 0)

local function ExecMinimize(forceState)
    if forceState ~= nil then State.IsMinimized = forceState else State.IsMinimized = not State.IsMinimized end
    SaveSystem()
    
    if State.IsMinimized then
        if mainFrame.Size.Y.Offset > 100 then lastMaximizedPos = mainFrame.Position end
        contentWrapper.Visible = false 
        minBtn.Visible = false
        TweenService:Create(mainFrame, Anim.Smooth, { Size = UDim2.new(0, 120, 0, 35), Position = UDim2.new(0, 50, 0.5, 0) }):Play()
        TweenService:Create(titleLabel, Anim.Fast, {TextTransparency = 1}):Play()
        TweenService:Create(statsDisplay, Anim.Smooth, { Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0, 0, 0, 0), TextColor3 = Theme.Primary }):Play()
        statsDisplay.TextXAlignment = Enum.TextXAlignment.Center
    else
        minBtn.Visible = true
        TweenService:Create(mainFrame, Anim.Smooth, { Size = UDim2.new(0, 560, 0, 440), Position = lastMaximizedPos }):Play()
        task.delay(0.2, function() contentWrapper.Visible = true end)
        TweenService:Create(titleLabel, Anim.Fast, {TextTransparency = 0}):Play()
        TweenService:Create(statsDisplay, Anim.Smooth, { Size = UDim2.new(1, -70, 1, 0), Position = UDim2.new(0, 10, 0, 0), TextColor3 = Theme.TextMuted }):Play()
        statsDisplay.TextXAlignment = Enum.TextXAlignment.Right
    end
end
minBtn.Activated:Connect(function() ExecMinimize() end)

local startClick = 0
local startClickPos = Vector3.new()
statsDisplay.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
        startClick = tick() 
        startClickPos = input.Position
    end
end)
statsDisplay.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if tick() - startClick < 0.4 and State.IsMinimized then 
            if (input.Position - startClickPos).Magnitude < 15 then ExecMinimize() end
        end
    end
end)

