local function formatKeyName(key)
    if not key then return "..." end
    local name = key.Name
    name = name:gsub("DPad", "D-"):gsub("Button", "Btn"):gsub("Control", "Ctrl"):gsub("Shift", "Shft")
    return string.sub(name, 1, 6)
end

