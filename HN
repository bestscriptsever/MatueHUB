local holdJumpPressed = false
local holdJumpActive = false
local manualJumpCooldown = false
local lastJumpTime = 0
local JUMP_COOLDOWN = 0.15
local lastAutoTpDownTime = 0

local function applyInfJumpBoost(boost)
    if not State.Toggles.InfJump then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        root.Velocity = Vector3.new(root.Velocity.X, boost, root.Velocity.Z)
    end
end

local function performInfiniteJump()
    if respawnPause or not State.Toggles.InfJump then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    if State.Values.JumpMode == "Hold" or State.Values.JumpMode == "Auto TP" then
        if tick() - lastJumpTime < JUMP_COOLDOWN then return end
        if hum.FloorMaterial ~= Enum.Material.Air then
            lastJumpTime = tick()
            applyInfJumpBoost(55)
        elseif holdJumpActive then
            lastJumpTime = tick()
            applyInfJumpBoost(55)
        end
    else
        if manualJumpCooldown then return end
        if tick() - lastJumpTime < JUMP_COOLDOWN then return end
        manualJumpCooldown = true
        lastJumpTime = tick()
        applyInfJumpBoost(55)
        task.delay(0.2, function() manualJumpCooldown = false end)
    end
end

local function hookMobileJump()
    pcall(function()
        local touchGui = player:WaitForChild("PlayerGui"):WaitForChild("TouchGui", 3)
        if touchGui then
            local jumpBtn = touchGui:FindFirstChild("JumpButton", true)
            if jumpBtn then
                jumpBtn.InputBegan:Connect(function(input)
                    if _G.Aimlock_Script_Versao ~= minhaVersao or not State.Toggles.InfJump then return end
                    if input.UserInputType == Enum.UserInputType.Touch then
                        if State.Values.JumpMode == "Hold" or State.Values.JumpMode == "Auto TP" then
                            holdJumpPressed = true
                            holdJumpActive = true
                            lastAutoTpDownTime = tick()
                            performInfiniteJump()
                        else
                            performInfiniteJump()
                        end
                    end
                end)
                jumpBtn.InputEnded:Connect(function(input)
                    if _G.Aimlock_Script_Versao ~= minhaVersao or not State.Toggles.InfJump then return end
                    if input.UserInputType == Enum.UserInputType.Touch then
                        holdJumpPressed = false
                        holdJumpActive = false
                    end
                end)
            end
        end
    end)
end

