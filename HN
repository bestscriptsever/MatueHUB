local function AutoAlignMobileButtons()
    local startX, startY = 0.85, 0.1
    local count = 0
    local scrSize = mobileGui.AbsoluteSize
    if scrSize.Y == 0 then scrSize = Vector2.new(800, 600) end
    
    for keyName, _ in pairs(State.Binds) do
        if State.MobileVis[keyName] then
            local stepX = (State.Values.MobSize + State.Values.MobSpacing) / scrSize.X
            local stepY = (State.Values.MobSize + State.Values.MobSpacing) / scrSize.Y
            
            local yPos = startY + (count * stepY)
            local xPos = startX
            if yPos > 0.85 then 
                count = 0
                startX = startX - stepX
                yPos = startY
            end
            State.MobilePositions[keyName] = {X = xPos, Y = yPos}
            
            local btn = mobileBtnsObjects[keyName]
            if btn then TweenService:Create(btn, Anim.Fast, {Position = UDim2.new(xPos, 0, yPos, 0)}):Play() end
            
            count = count + 1
        end
    end
    SaveSystem()
end

