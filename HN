        local bindBtnCorner = Instance.new("UICorner")
        bindBtnCorner.Name = "Corner"
        bindBtnCorner.Parent = bindBtn
        bindBtnCorner.CornerRadius = UDim.new(0, 6)
        
        local bindBtnStroke = Instance.new("UIStroke")
        bindBtnStroke.Name = "Stroke"
        bindBtnStroke.Parent = bindBtn
        bindBtnStroke.Color = Theme.Border
        
        table.insert(allKeybindButtonsList, {btn = bindBtn, name = keyName})

        bindBtn.Activated:Connect(function()
            if listeningAction then 
                listeningAction.btn.Text = formatKeyName(State.Binds[listeningAction.name]) 
            end
            bindBtn.Text = "..."
            listeningAction = { name = keyName, btn = bindBtn }
            TweenService:Create(bindBtn, Anim.Bounce, {Size = UDim2.new(0, 36, 0, 28)}):Play()
        end)
    end
