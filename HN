local function RefreshMobileButtons()
    if not State.Toggles.MobileMode then
        for _, btn in pairs(mobileBtnsObjects) do 
            btn.Visible = false 
        end
        return
    end

    for keyName, _ in pairs(State.Binds) do
        local btn = mobileBtnsObjects[keyName]
        if not btn then
            btn = Instance.new("TextButton")
            btn.Name = keyName .. "_MobileBtn"
            btn.Parent = mobileGui
            
            if State.MobilePositions[keyName] then
                btn.Position = UDim2.new(State.MobilePositions[keyName].X, 0, State.MobilePositions[keyName].Y, 0)
            else
                btn.Position = UDim2.new(0.8, 0, 0.5, 0)
            end

            btn.Font = Enum.Font.GothamBlack
            btn.TextSize = 11
            btn.TextWrapped = true
            
            local displayName = keyName
            if keyName == "AntiRagdoll" then displayName = "Anti\nRagdoll"
            elseif keyName == "AutoBat" then displayName = "Auto\nBat"
            elseif keyName == "AutoSteal" then displayName = "Auto\nSteal"
            elseif keyName == "InfJump" then displayName = "Inf\nJump"
            elseif keyName == "InstaReset" then displayName = "Insta\nReset"
            elseif keyName == "TPDown" then displayName = "TP\nDown"
            elseif keyName == "InstaPrompt" then displayName = "Insta\nPrompt"
            elseif keyName == "AutoInteract" then displayName = "Auto\nInteract"
            elseif keyName == "AutoLeft" then displayName = "Auto\nLeft"
            elseif keyName == "AutoRight" then displayName = "Auto\nRight"
            elseif keyName == "CarryMode" then displayName = "Carry\nMode" end
            
            btn.Text = string.upper(displayName)
            
            local corner = Instance.new("UICorner")
            corner.Name = "Corner"
            corner.Parent = btn
            corner.CornerRadius = UDim.new(1, 0)
            
            local stroke = Instance.new("UIStroke")
            stroke.Name = "Stroke"
            stroke.Parent = btn
            stroke.Thickness = 2.5
            stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            
            local btnScale = Instance.new("UIScale")
            btnScale.Name = "UIScale"
            btnScale.Parent = btn
            btnScale.Scale = State.Values.InterfaceScale / 100

            local isDragging, dragStart, startPos = false, nil, nil
            
            btn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    if State.Toggles.LockMobileBtns then
                        TweenService:Create(btnScale, Anim.Fast, {Scale = (State.Values.InterfaceScale / 100) * 0.9}):Play()
                        return
                    end
                    isDragging = false
                    dragStart = input.Position
                    startPos = btn.Position
                    TweenService:Create(btnScale, Anim.Fast, {Scale = (State.Values.InterfaceScale / 100) * 0.9}):Play()
                end
            end)
            
            btn.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                    if dragStart and not State.Toggles.LockMobileBtns and (input.Position - dragStart).Magnitude > 5 then
                        isDragging = true
                        local delta = input.Position - dragStart
                        local scrSize = mobileGui.AbsoluteSize
                        if scrSize.Y == 0 then scrSize = Vector2.new(800, 600) end
                        
                        local currentScale = State.Values.InterfaceScale / 100
                        local newX = math.clamp((startPos.X.Scale * scrSize.X + startPos.X.Offset + (delta.X / currentScale)) / scrSize.X, 0, 0.9)
                        local newY = math.clamp((startPos.Y.Scale * scrSize.Y + startPos.Y.Offset + (delta.Y / currentScale)) / scrSize.Y, 0, 0.9)
                        
                        if State.Toggles.MobGridMode then
                            local snapSizeX = (State.Values.MobSize + State.Values.MobSpacing) / scrSize.X
                            local snapSizeY = (State.Values.MobSize + State.Values.MobSpacing) / scrSize.Y
                            if snapSizeX > 0 and snapSizeY > 0 then
                                newX = math.floor(newX / snapSizeX + 0.5) * snapSizeX
                                newY = math.floor(newY / snapSizeY + 0.5) * snapSizeY
                            end
                        end
                        
                        btn.Position = UDim2.new(newX, 0, newY, 0)
                    end
                end
            end)
            
            btn.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    TweenService:Create(btnScale, Anim.Bounce, {Scale = State.Values.InterfaceScale / 100}):Play()
                    
                    if isDragging and not State.Toggles.LockMobileBtns then
                        State.MobilePositions[keyName] = {X = btn.Position.X.Scale, Y = btn.Position.Y.Scale}
                        SaveSystem()
                    else
                        if keyName == "TPDown" then 
                            if type(funcTPDown) == "function" then funcTPDown() end
                        elseif keyName == "Drop" then 
                            if type(runDropBrainrot) == "function" then runDropBrainrot() end
                        elseif keyName == "InstaReset" then 
                            if type(funcInstaReset) == "function" then funcInstaReset() end
                        elseif State.Toggles[keyName] ~= nil then
                            State.Toggles[keyName] = not State.Toggles[keyName]
                            if type(VisualUpdaters[keyName]) == "table" then
                                for _, fn in ipairs(VisualUpdaters[keyName]) do 
                                    if type(fn) == "function" then fn(State.Toggles[keyName]) end 
                                end
                            end
                            if type(LogicActions[keyName]) == "function" then 
                                LogicActions[keyName]() 
                            end
                            SaveSystem()
                        end
                    end
                    dragStart = nil
                    isDragging = false
                end
            end)
            
            mobileBtnsObjects[keyName] = btn
        end

        if State.MobileVis[keyName] == false then
            btn.Visible = false
        else
            btn.Visible = true
            btn.Size = UDim2.new(0, State.Values.MobSize, 0, State.Values.MobSize)
            btn.BackgroundTransparency = State.Values.MobTransp
            
            local textAlpha = math.clamp(State.Values.MobTransp - 0.2, 0, 1)
            btn.TextTransparency = textAlpha
            
            local btnScale = btn:FindFirstChildOfClass("UIScale")
            if btnScale then btnScale.Scale = State.Values.InterfaceScale / 100 end
            
            local stroke = btn:FindFirstChildOfClass("UIStroke")
            if stroke then stroke.Transparency = State.Values.MobTransp end
            
            if State.Toggles[keyName] then
                btn.BackgroundColor3 = Theme.Primary
                btn.TextColor3 = Theme.Background
                if stroke then stroke.Color = Theme.Background end
            else
                btn.BackgroundColor3 = Theme.Surface
                btn.TextColor3 = Theme.Text
                if stroke then stroke.Color = Theme.Border end
            end
        end
    end
end

