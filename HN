        b.Font = Enum.Font.GothamBold
        b.TextSize = 12
        b.TextColor3 = Theme.Text
        b.Text = txt
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
        return b
    end

    local btnKick = createActionBtn("KICK PLAYER", Theme.PrimaryDark)
    local btnWarn = createActionBtn("ENVIAR AVISO", Theme.SurfaceHover)
    local btnKill = createActionBtn("KILL PLAYER", Theme.Danger)
    local btnFreeze = createActionBtn("FREEZE PLAYER", Color3.fromRGB(0, 150, 255))
    local btnUnfreeze = createActionBtn("UNFREEZE", Color3.fromRGB(50, 200, 100))
    local btnFling = createActionBtn("FLING PLAYER", Color3.fromRGB(255, 100, 0))

    local function executeAdminAction(typeAction, successMsg)
        if selectedHubUser then
            local reason = adminReasonBox.Text ~= "" and adminReasonBox.Text or "Executado pela Administração."
            
            -- Se for o próprio player que acionou, testa localmente direto (Bypassando RLS e AntiKick)
            if selectedHubUser.userid == tostring(player.UserId) then
                if typeAction == "kick" then 
                    ExecuteKick("\nMATUE HUB - KICK ADMINISTRATIVO\n\n" .. reason)
                elseif typeAction == "warn" then 
                    ShowGiantWarning(reason)
                elseif typeAction == "kill" then 
                    if player.Character and player.Character:FindFirstChild("Humanoid") then 
                        player.Character.Humanoid.Health = 0 
                    end
                elseif typeAction == "freeze" then 
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then 
                        player.Character.HumanoidRootPart.Anchored = true
                        if player.Character:FindFirstChild("Humanoid") then
                            player.Character.Humanoid.WalkSpeed = 0
                        end
                    end
                elseif typeAction == "unfreeze" then 
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then 
                        player.Character.HumanoidRootPart.Anchored = false
                        if player.Character:FindFirstChild("Humanoid") then
                            player.Character.Humanoid.WalkSpeed = 16
                        end
                    end
                elseif typeAction == "fling" then 
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then 
                        player.Character.HumanoidRootPart.Velocity = Vector3.new(0, 50000, 0) 
                    end 
                end
            end

            -- Disparo via Supabase para afetar players globalmente e em outros clients
            pcall(function()
                SupabaseRequest("/rest/v1/announcements", "POST", {
                    userid = tostring(selectedHubUser.userid),
                    type = typeAction,
                    message = reason
                })
            end)
            
            Notificar("AÇÃO EXECUTADA", successMsg .. selectedHubUser.username)
        else
            Notificar("ERRO DE AÇÃO", "Selecione um jogador da lista primeiro.")
        end
    end

    btnKick.Activated:Connect(function() executeAdminAction("kick", "KICK enviado para: ") end)
    btnWarn.Activated:Connect(function() executeAdminAction("warn", "AVISO GIGANTE enviado para: ") end)
    btnKill.Activated:Connect(function() executeAdminAction("kill", "KILL enviado para: ") end)
    btnFreeze.Activated:Connect(function() executeAdminAction("freeze", "FREEZE enviado para: ") end)
    btnUnfreeze.Activated:Connect(function() executeAdminAction("unfreeze", "UNFREEZE enviado para: ") end)
    btnFling.Activated:Connect(function() executeAdminAction("fling", "FLING absurdo enviado para: ") end)

    local playerListContainer = Instance.new("ScrollingFrame", adminScroll)
    playerListContainer.Size = UDim2.new(1, -20, 0, 180)
    playerListContainer.BackgroundColor3 = Theme.Background
    playerListContainer.BorderSizePixel = 0
    playerListContainer.ScrollBarThickness = 3
    playerListContainer.ScrollBarImageColor3 = Theme.Primary
    Instance.new("UICorner", playerListContainer).CornerRadius = UDim.new(0, 8)
    
    local plLayout = Instance.new("UIListLayout", playerListContainer)
    plLayout.Padding = UDim.new(0, 5)
    plLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        playerListContainer.CanvasSize = UDim2.new(0, 0, 0, plLayout.AbsoluteContentSize.Y + 10)
    end)
    Instance.new("UIPadding", playerListContainer).PaddingTop = UDim.new(0, 5)

    -- A grande correção da Lista: Busca do Server Atual e Search engine funcional
    local function RefreshAdminPlayerList()
        local filter = string.lower(searchBox.Text)
        local currentPlayers = Players:GetPlayers()
        if not currentPlayers then return end

        for _, v in ipairs(playerListContainer:GetChildren()) do
            if v:IsA("TextButton") then v:Destroy() end
        end

        for _, p in ipairs(currentPlayers) do
            local pname = string.lower(p.Name)
            local pdname = string.lower(p.DisplayName)
            local pid = tostring(p.UserId)
            
            if filter == "" or string.find(pname, filter) or string.find(pdname, filter) or string.find(pid, filter) then
                local btn = Instance.new("TextButton", playerListContainer)
                btn.Size = UDim2.new(1, -10, 0, 30)
                btn.BackgroundColor3 = Theme.Surface
                btn.BorderSizePixel = 0
                btn.Font = Enum.Font.GothamMedium
                btn.TextSize = 12
                btn.TextColor3 = Theme.TextMuted
                btn.Text = "   [" .. p.UserId .. "] " .. p.Name
                btn.TextXAlignment = Enum.TextXAlignment.Left
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
                
                if selectedHubUser and selectedHubUser.userid == tostring(p.UserId) then
                    btn.BackgroundColor3 = Theme.Primary
                    btn.TextColor3 = Theme.Background
                end

                btn.Activated:Connect(function()
                    selectedHubUser = {userid = tostring(p.UserId), username = p.Name}
                    lblTarget.Text = "Alvo Selecionado: " .. p.Name .. " (" .. p.UserId .. ")"
                    
                    for _, v in ipairs(playerListContainer:GetChildren()) do 
                        if v:IsA("TextButton") then 
                            TweenService:Create(v, Anim.Fast, {BackgroundColor3 = Theme.Surface, TextColor3 = Theme.TextMuted}):Play() 
                        end 
                    end
                    TweenService:Create(btn, Anim.Fast, {BackgroundColor3 = Theme.Primary, TextColor3 = Theme.Background}):Play()
                end)
            end
        end
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(RefreshAdminPlayerList)

    Players.PlayerAdded:Connect(function()
        if tabAdmin.Visible then RefreshAdminPlayerList() end
    end)
    
    Players.PlayerRemoving:Connect(function()
        if tabAdmin.Visible then RefreshAdminPlayerList() end
    end)

    task.spawn(function()
        while task.wait(1) do
            if _G.Aimlock_Script_Versao ~= minhaVersao then break end
            if tabAdmin.Visible then
                pcall(RefreshAdminPlayerList)
            end
        end
    end)
end

