    overlay.ZIndex = 50

    local function VisualUpdate(isActive)
        if isActive then
            TweenService:Create(pill, Anim.Smooth, {BackgroundColor3 = Theme.Primary}):Play()
            TweenService:Create(dot, Anim.Bounce, {Position = UDim2.new(1, -19, 0.5, 0), BackgroundColor3 = Theme.Background}):Play()
            TweenService:Create(fStroke, Anim.Smooth, {Color = Theme.Primary}):Play()
            TweenService:Create(title, Anim.Smooth, {TextColor3 = Theme.Primary}):Play()
        else
            TweenService:Create(pill, Anim.Smooth, {BackgroundColor3 = Theme.Background}):Play()
            TweenService:Create(dot, Anim.Bounce, {Position = UDim2.new(0, 3, 0.5, 0), BackgroundColor3 = Theme.TextMuted}):Play()
            TweenService:Create(fStroke, Anim.Smooth, {Color = Theme.Border}):Play()
            TweenService:Create(title, Anim.Smooth, {TextColor3 = Theme.Text}):Play()
        end
        
        local mobBtn = mobileBtnsObjects[stateKey]
        if mobBtn then
            if isActive then
                mobBtn.BackgroundColor3 = Theme.Primary
                mobBtn.TextColor3 = Theme.Background
                local strk = mobBtn:FindFirstChildOfClass("UIStroke")
                if strk then strk.Color = Theme.Background end
            else
                mobBtn.BackgroundColor3 = Theme.Surface
                mobBtn.TextColor3 = Theme.Text
                local strk = mobBtn:FindFirstChildOfClass("UIStroke")
                if strk then strk.Color = Theme.Border end
            end
        end
    end
    
    if not VisualUpdaters[stateKey] then 
        VisualUpdaters[stateKey] = {} 
    end
    table.insert(VisualUpdaters[stateKey], VisualUpdate)

    overlay.Activated:Connect(function()
        State.Toggles[stateKey] = not State.Toggles[stateKey]
        if type(VisualUpdaters[stateKey]) == "table" then 
            for _, fn in ipairs(VisualUpdaters[stateKey]) do 
                if type(fn) == "function" then 
                    fn(State.Toggles[stateKey]) 
                end 
            end 
        end
        
        if type(LogicActions[stateKey]) == "function" then 
            LogicActions[stateKey]() 
        end
        SaveSystem()
        
        local t = TweenService:Create(frame, Anim.Fast, {Size = UDim2.new(1, -24, 0, 46)})
        t:Play()
        t.Completed:Wait()
        TweenService:Create(frame, Anim.Bounce, {Size = UDim2.new(1, -20, 0, 48)}):Play()
    end)
    
    overlay.MouseEnter:Connect(function() 
        TweenService:Create(frame, Anim.Fast, {BackgroundColor3 = Theme.SurfaceHover}):Play() 
    end)
    
    overlay.MouseLeave:Connect(function() 
        TweenService:Create(frame, Anim.Fast, {BackgroundColor3 = Theme.Surface}):Play() 
    end)

    if keyName then
        local bindBtn = Instance.new("TextButton")
        bindBtn.Name = "BindButton"
        bindBtn.Parent = frame
        bindBtn.Size = UDim2.new(0, 30, 0, 24)
        bindBtn.AnchorPoint = Vector2.new(1, 0.5)
        bindBtn.Position = UDim2.new(1, -70, 0.5, 0)
