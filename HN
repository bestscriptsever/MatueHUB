        if State.Binds[obj.name] then obj.btn.Text = formatKeyName(State.Binds[obj.name]) end
    end
end

local function listarConfigs()
    if not listfiles then return {} end
    local files = {}
    pcall(function()
        for _, path in ipairs(listfiles(ConfigFolder)) do
            local file = string.match(path, "([^/\\]+)%.json$")
            if file and file ~= "AutoSave.json" then table.insert(files, file) end
        end
    end)
    return files
end

local function salvarConfig(nomeArquivo)
    if not writefile then return Notificar("Erro", "Falha de compatibilidade.") end
    if nomeArquivo == "" or nomeArquivo:lower() == "textbox" then nomeArquivo = "padrao" end
    local cfgs = listarConfigs()
    local jaExiste = false
    for _, v in ipairs(cfgs) do if v:lower() == nomeArquivo:lower() then jaExiste = true break end end
    if not jaExiste and #cfgs >= 5 then return Notificar("Limite", "Delete uma config para salvar (Max: 5).") end
    
    local dataToSave = { Binds = {}, Values = State.Values, MobilePositions = State.MobilePositions, MobileVis = State.MobileVis }
    for k, v in pairs(State.Binds) do dataToSave.Binds[k] = v.Name end
    
    local success = pcall(function() writefile(ConfigFolder.."/"..nomeArquivo..".json", HttpService:JSONEncode(dataToSave)) end)
    if success then Notificar("Save", "["..nomeArquivo.."] salva!") end
end

local function carregarConfig(nomeArquivo)
    if not readfile or not isfile(ConfigFolder.."/"..nomeArquivo..".json") then return end
    local success, result = pcall(function() return HttpService:JSONDecode(readfile(ConfigFolder.."/"..nomeArquivo..".json")) end)
    if success and type(result) == "table" then
        if result.Values then
            for k, v in pairs(result.Values) do 
                State.Values[k] = v 
                if type(InputUpdaters[k]) == "function" then InputUpdaters[k](v) end
            end
        end
        if result.Binds then
            for k, v in pairs(result.Binds) do pcall(function() State.Binds[k] = Enum.KeyCode[v] end) end
        end
        if result.MobilePositions then
            for k, v in pairs(result.MobilePositions) do State.MobilePositions[k] = v end
        end
        if result.MobileVis then
            for k, v in pairs(result.MobileVis) do State.MobileVis[k] = v end
        end
        atualizarTextosDosBotoes()
        if type(LogicActions.MobileMode) == "function" then LogicActions.MobileMode() end
        if type(LogicActions.InterfaceScale) == "function" then LogicActions.InterfaceScale() end
        Notificar("Load", "["..nomeArquivo.."] carregada!")
        SaveSystem()
    end
end

local function deletarConfig(nomeArquivo)
    if not delfile then return end
    local path = ConfigFolder.."/"..nomeArquivo..".json"
    if isfile(path) then pcall(function() delfile(path) end); Notificar("Delete", "Apagada.") end
end

