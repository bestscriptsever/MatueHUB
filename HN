    billboard.StudsOffset = Vector3.new(0, 4, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = head
    
    local label = Instance.new("TextLabel")
    label.Name = "Label"
    label.Parent = billboard
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "3"
    label.TextColor3 = Theme.Primary
    label.Font = Enum.Font.GothamBlack
    label.TextSize = 0
    label.TextStrokeTransparency = 0.2
    label.TextStrokeColor3 = Color3.fromRGB(0, 20, 40)
    
    countdownBillboard = billboard
    return label
end

local function startCountdown()
    if countdownActive then return end
    local label = createCountdownDisplay()
    if not label then return end
    
    countdownActive = true
    
    task.spawn(function()
        for i = 3, 1, -1 do
            if not countdownActive then break end
            label.Text = tostring(i)
            
            label.TextSize = 0
            TweenService:Create(label, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {TextSize = 55}):Play()
            
            if i == 3 then 
                label.TextColor3 = Theme.Primary 
            elseif i == 2 then 
                label.TextColor3 = Color3.fromRGB(0, 150, 255) 
            elseif i == 1 then 
                label.TextColor3 = Color3.fromRGB(100, 255, 200) 
            end
            
            if i > 1 then task.wait(1) end
        end
        task.wait(1)
        if countdownBillboard then 
            pcall(function() countdownBillboard:Destroy() end)
            countdownBillboard = nil 
        end
        countdownActive = false
    end)
end

